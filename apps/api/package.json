{
	"name": "@juicerq/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/app.ts",
		"build": "bun build ./src/app.ts --outdir ./dist --target bun",
		"start": "bun src/app.ts",
		"typecheck": "tsgo -p tsconfig.json",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run src/db/migrate.ts",
		"db:studio": "drizzle-kit studio",
		"db:reset": "bun run src/db/reset.ts",
		"db:check": "drizzle-kit check",
		"agent-orpc": "bun run src/agent-orpc.ts"
	},
	"dependencies": {
		"@juicerq/observability": "workspace:*",
		"@orpc/server": "^1.14.0",
		"arktype": "^2.2.0",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.14",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"bun-types": "^1.3.13",
		"drizzle-kit": "^0.31.10"
	}
}
